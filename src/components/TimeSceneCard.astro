---
import type { ImageMetadata } from 'astro:assets';
import { splitLines } from '../utils/text';
import { CDN_URL } from '../data/links';

interface Props {
  name: string;
  price: string;
  description: string;
  href?: string;
  mainImage: ImageMetadata;
  subImage: ImageMetadata;
}

const { name, price, description, href = '#', mainImage, subImage } = Astro.props;
const nameLines = splitLines(name);
const descLines = splitLines(description);
const cdnBase = CDN_URL ? CDN_URL.replace(/\/$/, '') : '';
const toAssetSrc = (src: string) => (import.meta.env.PROD && cdnBase ? `${cdnBase}${src}` : src);
---

<article class="c-time-scene-card">
  <div class="c-time-scene-card__heading">
    <h3 class="c-time-scene-card__name">
      {nameLines.map((line, i) => (
        <>{line}{i < nameLines.length - 1 && <br />}</>
      ))}
    </h3>

    <p class="c-time-scene-card__price">
      <span class="c-time-scene-card__price-yen">¥</span>
      {price}
      <span class="c-time-scene-card__price-tax">(税込)</span>
    </p>
  </div>

  <div class="c-time-scene-card__visual">
    <div class="c-time-scene-card__inset">
      <img
        src={toAssetSrc(subImage.src)}
        alt={`${nameLines[0]}のサブ画像`}
        width={subImage.width}
        height={subImage.height}
        loading="lazy"
        decoding="async"
        class="c-time-scene-card__inset-image"
      />
    </div>

    <div class="c-time-scene-card__image">
      <div class="c-time-scene-card__image-frame">
        <img
          src={toAssetSrc(mainImage.src)}
          alt={`${nameLines[0]}のメイン画像`}
          width={mainImage.width}
          height={mainImage.height}
          loading="lazy"
          decoding="async"
          class="c-time-scene-card__image-el"
        />
      </div>
    </div>

    <div class="c-time-scene-card__desc-box">
      <p class="c-time-scene-card__desc">
        {descLines.map((line, i) => (
          <>{line}{i < descLines.length - 1 && <br />}</>
        ))}
      </p>
    </div>
  </div>

  <div class="c-time-scene-card__btn">
    <a href={href} class="c-btn-pill">
      <span>詳しくはこちら</span>
      <span class="c-btn-pill__arrow" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="11" fill="currentColor" />
          <path d="M10 8l4 4-4 4" stroke="var(--pill-arrow-color, currentColor)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
    </a>
  </div>
</article>
