---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import flowerRanking from '../assets/images/flower-ranking.png';
import ranking1Image from '../assets/images/ranking1_img.jpg';
import ranking2Image from '../assets/images/ranking2_img.jpg';
import ranking3Image from '../assets/images/ranking3_img.jpg';
import { splitLines } from '../utils/text';

const rankingEntries = await getCollection('ranking');
const rankingItems = rankingEntries.map((entry) => entry.data);
const rankingImagesByRank = {
  1: ranking1Image,
  2: ranking2Image,
  3: ranking3Image,
} as const;
const rankingBackHanaByRank = {
  1: { tr: '/ranking1_hana-1.svg', bl: '/ranking1_hana-2.svg' },
  2: { tr: '/ranking2_hana-1.svg', bl: '/ranking2_hana-2.svg' },
  3: { tr: '/ranking3_hana-1.svg', bl: '/ranking3_hana-2.svg' },
} as const;
const isNameSupplementLine = (line: string) => /^\s*[（(].*[）)]\s*$/.test(line);
const splitNameInlineSegments = (line: string) => line.split(/([［\[].*?[］\]])/g).filter(Boolean);
const isNameInlineSupplement = (segment: string) => /^\[.*?\]$/.test(segment);
---

<section id="ranking" class="l-section p-ranking" aria-labelledby="heading-ranking">
  <div class="l-container">
    <header class="p-ranking__header">
      <Image src={flowerRanking} alt="" class="p-ranking__flower" />
      <img src="/ranking.svg" alt="Ranking" class="p-ranking__title-en-img" />
    </header>

    <div class="p-ranking__list-wrapper">
      <h2 id="heading-ranking" class="p-ranking__title">
        母の日<br />
        人気ギフトランキング
      </h2>

      <ol class="p-ranking__list">
        {rankingItems.map((item) => (
          <li class="p-ranking__item">
            <div class="c-ranking-card is-flipped" data-flip-card data-rank={item.rank}>
              <div class="c-ranking-card__inner">
                <a href={item.href} class="c-ranking-card__front" aria-label={`${item.name}の商品ページ`}>
                  <div class="c-ranking-card__front-content">
                    <div class="c-ranking-card__badge-sm">
                      <div class="c-ranking-card__badge-sm-row">
                        <img src="/kusa.svg" alt="" class="c-ranking-card__kusa c-ranking-card__kusa--left" aria-hidden="true" />
                        <img src={`/no${item.rank}.svg`} alt={`No.${item.rank}`} class="c-ranking-card__no-img" />
                        <img src="/kusa.svg" alt="" class="c-ranking-card__kusa c-ranking-card__kusa--right" aria-hidden="true" />
                      </div>
                    </div>

                    <div class="c-ranking-card__media">
                      <div class="c-ranking-card__image">
                        <Image
                          src={rankingImagesByRank[item.rank as 1 | 2 | 3]}
                          alt={`${item.name.replace('\n', '')}の商品画像`}
                          class="c-ranking-card__image-el"
                        />
                      </div>

                      <div class="c-ranking-card__body">
                        <div class="c-ranking-card__summary">
                          <h3 class="c-ranking-card__name">
                            {splitLines(item.name).map((line, index, lines) => (
                              <Fragment>
                                <span class:list={['c-ranking-card__name-line', isNameSupplementLine(line) && 'c-ranking-card__name-line--sub']}>
                                  {splitNameInlineSegments(line).map((segment) => (
                                    <span class:list={[isNameInlineSupplement(segment) && 'c-ranking-card__name-inline-sub']}>
                                      {segment}
                                    </span>
                                  ))}
                                </span>
                                {index < lines.length - 1 && <br />}
                              </Fragment>
                            ))}
                          </h3>
                          <div class="c-ranking-card__divider" role="separator"></div>
                          <p class="c-ranking-card__desc">{item.description}</p>
                        </div>
                        <p class="c-ranking-card__price">
                          <span class="c-ranking-card__price-yen">¥</span>{item.price}<span class="c-ranking-card__price-tax">(税込)</span>
                        </p>
                      </div>
                    </div>
                  </div>
                </a>

                <div class="c-ranking-card__back">
                  <div class="c-ranking-card__back-face">
                    <img
                      src={rankingBackHanaByRank[item.rank as 1 | 2 | 3].tr}
                      alt=""
                      class="c-ranking-card__back-hana c-ranking-card__back-hana--tr"
                      aria-hidden="true"
                    />
                    <img
                      src={rankingBackHanaByRank[item.rank as 1 | 2 | 3].bl}
                      alt=""
                      class="c-ranking-card__back-hana c-ranking-card__back-hana--bl"
                      aria-hidden="true"
                    />
                    <div class="c-ranking-card__badge-lg">
                      <img src="/star.svg" alt="" class="c-ranking-card__badge-lg-star" aria-hidden="true" />
                      <div class="c-ranking-card__badge-lg-row">
                        <img src="/kusa.svg" alt="" class="c-ranking-card__kusa c-ranking-card__kusa--lg" aria-hidden="true" />
                        <img src={`/no${item.rank}.svg`} alt={`No.${item.rank}`} class="c-ranking-card__badge-lg-no-img" />
                        <img src="/kusa.svg" alt="" class="c-ranking-card__kusa c-ranking-card__kusa--right c-ranking-card__kusa--lg" aria-hidden="true" />
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('[data-flip-card]').forEach((card) => {
    const handleCardClick = () => {
      card.classList.remove('is-flipped');
      card.removeEventListener('click', handleCardClick);
    };

    card.addEventListener('click', handleCardClick);
  });
</script>
