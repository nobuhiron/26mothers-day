---
/**
 * 価格帯で選ぶ
 */
import PriceBandCard from '../components/PriceBandCard.astro';
import { getCollection } from 'astro:content';
import { formatPriceBandLabel } from '../utils/text';
import { Image } from 'astro:assets';
import wrappingImg from '../assets/images/wrapping_img.png';
import flowerPriceImg1 from '../assets/images/flower-price-1.png';
import flowerPriceImg2 from '../assets/images/flower-price-2.png';
import price1000_1 from '../assets/images/price-1000-1.jpg';
import price1000_2 from '../assets/images/price-1000-2.jpg';
import price1000_3 from '../assets/images/price-1000-3.jpg';
import price2000_1 from '../assets/images/price-2000-1.jpg';
import price2000_2 from '../assets/images/price-2000-2.jpg';
import price2000_3 from '../assets/images/price-2000-3.jpg';
import price4000_1 from '../assets/images/price-4000-1.jpg';
import price4000_2 from '../assets/images/price-4000-2.jpg';
import price4000_3 from '../assets/images/price-4000-3.jpg';
import price6000_1 from '../assets/images/price-6000-1.jpg';
import price6000_2 from '../assets/images/price-6000-2.jpg';
import price6000_3 from '../assets/images/price-6000-3.jpg';

const pbEntries = await getCollection('priceBands');
const bands = pbEntries.map((e) => e.data);

const bandImages = {
  'band-1': [price1000_1, price1000_2, price1000_3],
  'band-2': [price2000_1, price2000_2, price2000_3],
  'band-3': [price4000_1, price4000_2, price4000_3],
  'band-4': [price6000_1, price6000_2, price6000_3],
} as const;
---

<section id="price" class="l-section l-section--bg-surface p-shop-by-price" aria-labelledby="heading-price">
  <!-- ヘッダー -->
  <header class="p-shop-by-price__header">
    <div class="p-shop-by-price__header-decor" aria-hidden="true">
      <Image src={flowerPriceImg1} alt="" class="p-shop-by-price__header-decor-image p-shop-by-price__header-decor-image--1" />
      <Image src={flowerPriceImg2} alt="" class="p-shop-by-price__header-decor-image p-shop-by-price__header-decor-image--2" />
    </div>
    <h2 id="heading-price" class="p-shop-by-price__heading">
      <img src="/Shop by price.svg" alt="Shop by price" class="p-shop-by-price__heading-en-img" />
      <span class="p-shop-by-price__heading-ja">母の日限定包装紙でお包み<br />価格帯でえらぶ</span>
    </h2>
    <div class="p-shop-by-price__header-visual" aria-hidden="true">
      <span class="p-shop-by-price__header-band"></span>
      <div class="p-shop-by-price__header-image-frame">
        <img src={wrappingImg.src} alt="" class="p-shop-by-price__header-image" />
      </div>
    </div>
  </header>

  <div class="l-container">
    <!-- 価格帯グループ -->
    <div class="p-shop-by-price__bands">
      {bands.map((band) => (
        <section class="p-shop-by-price__band" aria-labelledby={`heading-${band.id}`}>
          <header class="p-shop-by-price__band-header">
            {/* アーチSVG用スペース */}
            <div class="p-shop-by-price__band-arch" aria-hidden="true">
              <img src={band.arch} alt={band.labelEn} class="p-shop-by-price__band-arch-img" />
            </div>
            <h3 id={`heading-${band.id}`} class="p-shop-by-price__band-title">
              {formatPriceBandLabel(band.label).map((part) => (
                part.className ? <span class={part.className}>{part.text}</span> : part.text
              ))}
              <span class="p-shop-by-price__band-sub">おすすめアイテム</span>
            </h3>
          </header>
          <ul class="p-shop-by-price__list">
            {band.items.map((product, index) => (
              <li>
                <PriceBandCard
                  name={product.name}
                  price={product.price}
                  description={product.description}
                  href={product.href}
                  image={bandImages[band.id as keyof typeof bandImages][index]}
                />
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </div>
</section>
