---
/**
 * 配送・締切
 * 残り日数は 0–99 を想定し、常に2桁（白枠2つ）で表示
 */
import { PUBLIC_MOTHERS_DAY_COUNTDOWN } from 'astro:env/server';
const daysLeft = Math.min(99, Math.max(0, Math.floor(PUBLIC_MOTHERS_DAY_COUNTDOWN)));
const digitStr = String(daysLeft).padStart(2, '0');
const digitTens = digitStr[0];
const digitOnes = digitStr[1];
---

<section id="delivery" class="p-delivery-info" aria-labelledby="heading-delivery">
  <div class="l-container">
    <h2 id="heading-delivery" class="visually-hidden">配送・締切</h2>
    <div class="p-delivery-info__inner">

      {/* 年バッジ（リボン + 2026） */}
      <div class="p-delivery-info__year-badge">
        <img src="/ribon.svg" alt="" class="p-delivery-info__year-ribbon" width="129" height="29" />
        <img src="/2026.svg" alt="2026" class="p-delivery-info__year-text" width="48" height="12" />
      </div>

      {/* 母の日は 5.10 */}
      <p class="p-delivery-info__date-line">
        <span class="p-delivery-info__date-prefix">母の日は</span>
        <span class="p-delivery-info__date-value">5.10</span>
        <span class="p-delivery-info__date-wday">［sun］</span>
      </p>

      {/* あと [桁][桁] 日 */}
      <p class="p-delivery-info__countdown-line">
        <span class="p-delivery-info__count-text">あと</span>
        <span class="p-delivery-info__digits" aria-label={`あと${daysLeft}日`}>
          <span class="p-delivery-info__digit">{digitTens}</span>
          <span class="p-delivery-info__digit">{digitOnes}</span>
        </span>
        <span class="p-delivery-info__count-text">日</span>
      </p>

      {/* 配達情報 */}
      <div class="p-delivery-info__notice">
        <img src="/delivery-icon.svg" alt="" class="p-delivery-info__notice-icon" width="32" height="32" />
        <p class="p-delivery-info__tagline">
          <span class="p-delivery-info__tagline-black">母の日</span><strong class="p-delivery-info__tagline-em">当日配達可能</strong><span class="p-delivery-info__tagline-black">です</span>
        </p>
        <p class="p-delivery-info__deadline">
          <strong class="p-delivery-info__deadline-em">5月6日(水)</strong><span class="p-delivery-info__deadline-em">午前</span><strong class="p-delivery-info__deadline-em">10</strong><span class="p-delivery-info__deadline-em">時まで</span>に<br />ご注文ください。
        </p>
      </div>

    </div>
  </div>
</section>
