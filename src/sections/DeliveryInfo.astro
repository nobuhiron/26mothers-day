---
/**
 * 配送情報セクション
 */
import { Image } from 'astro:assets';
import flowerDelivery from '../assets/images/flower-delivery.png';

const today = new Date();
const target = new Date(today.getFullYear(), 4, 10); // 5/10
if (target <= today) target.setFullYear(today.getFullYear() + 1);
const daysLeft = Math.min(99, Math.max(0, Math.ceil((target.getTime() - today.getTime()) / 86400000)));
const digitStr = String(daysLeft).padStart(2, '0');
const digitTens = digitStr[0];
const digitOnes = digitStr[1];
---

<section id="delivery" class="p-delivery-info" aria-labelledby="heading-delivery">
  <Image src={flowerDelivery} alt="" class="p-delivery-info__flower" aria-hidden="true" />
  <div class="l-container">
    <h2 id="heading-delivery" class="visually-hidden">配送情報</h2>
    <div class="p-delivery-info__inner">
      <div class="p-delivery-info__lead">
        {/* 年バッジ（リボン + 2026） */}
        <div class="p-delivery-info__year-badge">
          <img src="/ribon.svg" alt="" class="p-delivery-info__year-ribbon" width="129" height="29" />
          <img src="/2026.svg" alt="2026" class="p-delivery-info__year-text" width="48" height="12" />
        </div>

        {/* 母の日は 5.10 */}
        <p class="p-delivery-info__date-line">
          <span class="p-delivery-info__date-prefix">母の日<span class="p-delivery-info__date-prefix-em">は</span></span>
          <span class="p-delivery-info__date-value">5.10<span class="p-delivery-info__date-wday">[sun]</span></span>
        </p>

        {/* あと XX 日 */}
        <p class="p-delivery-info__countdown-line">
          <span class="p-delivery-info__count-text">あと</span>
          <span class="p-delivery-info__digits" aria-label={`あと${daysLeft}日`}>
            <span class="p-delivery-info__digit">{digitTens}</span>
            <span class="p-delivery-info__digit">{digitOnes}</span>
          </span>
          <span class="p-delivery-info__count-text">日</span>
        </p>
      </div>

      {/* 配送案内 */}
      <div class="p-delivery-info__notice">
        <img src="/delivery-icon.svg" alt="" class="p-delivery-info__notice-icon" width="32" height="32" />
        <p class="p-delivery-info__tagline">
          <span class="p-delivery-info__tagline-black">母の日</span><span class="p-delivery-info__tagline-em">当日配達可能</span><span class="p-delivery-info__tagline-black">です</span>
        </p>
        <p class="p-delivery-info__deadline">
          <span class="p-delivery-info__deadline-num">5</span><span class="p-delivery-info__deadline-unit">月</span><span class="p-delivery-info__deadline-num">6</span><span class="p-delivery-info__deadline-unit">日</span><span class="p-delivery-info__deadline-unit">(水)</span>
          <span class="p-delivery-info__deadline-time-em">午前</span><span class="p-delivery-info__deadline-num">10</span><span class="p-delivery-info__deadline-time-em">時</span><span class="p-delivery-info__deadline-until">までに</span><br /><span class="p-delivery-info__deadline-cta">ご注文ください。</span>
        </p>
      </div>

    </div>
  </div>
</section>
