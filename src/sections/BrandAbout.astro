---
/**
 * About section / LINE chat UI
 */
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import ReasonCarousel from '../components/ReasonCarousel.astro';
import chatData from '../data/line-chat.json';
import kumaIconInitial from '../assets/images/icon_kuma4.png';
import kumaIconReplyA1 from '../assets/images/icon_kuma2.png';
import kumaIconReplyA2 from '../assets/images/icon_kuma1.png';
import kumaIconFooter from '../assets/images/icon_kuma3.png';
import choiceIcon from '../assets/images/icon_usagi.png';
import boxImg from '../assets/images/box_img.png';
import tagImg1 from '../assets/images/tag-img-1.jpg';
import tagImg2 from '../assets/images/tag-img-2.jpg';
import wrappingImg from '../assets/images/wrapping_img.png';

const brandEntries = await getCollection('brandCards');
const brandCarouselCards = brandEntries.map((entry) => ({
  reason: entry.data.reason,
  title: entry.data.title,
  description: entry.data.description,
  buttons: entry.data.cta ? [entry.data.cta] : [],
}));
const replyAAvatars = [kumaIconReplyA1, kumaIconReplyA2];
const replyBAvatars = [kumaIconReplyA1, kumaIconReplyA2];
const reasonHeading = '森半が選ばれる理由';
const giftCarouselCards = [
  {
    reason: 'Gift 01',
    title: '贈りものにちょうどいいセット',
    description:
      '用途や予算に合わせて選びやすい組み合わせです。\nラッピングや熨斗の相談もまとめてできます。',
    image: boxImg,
    imageAlt: 'ギフトボックスのイメージ',
    buttons: ['ギフトラッピングについて', '贈り方ガイド'],
  },
  {
    reason: 'Gift 02',
    title: '季節のご挨拶に合う手土産',
    description:
      '相手を選びにくく、持ち運びもしやすい内容です。\nちょっとしたお礼にも使いやすいカードです。',
    image: tagImg1,
    imageAlt: '季節の手土産のイメージ',
    buttons: ['用途で選ぶ'],
  },
  {
    reason: 'Gift 03',
    title: '日持ちや保存が気になるときに',
    description:
      'すぐに食べきらなくてもよいものを選びたいときに向いています。\n配りやすさも重視したい場面に合います。',
    image: tagImg2,
    imageAlt: '保存しやすい贈りもののイメージ',
    buttons: [],
  },
  {
    reason: 'Gift 04',
    title: '少し特別感を出したいときに',
    description:
      'ラッピングを添えることで、贈りものとしての印象を高められます。\n記念日やきちんとした場面にも使いやすいです。',
    image: wrappingImg,
    imageAlt: 'ラッピングされた贈りもののイメージ',
    buttons: [],
  },
];
---

<section id="about" class="l-section p-brand-about" aria-labelledby="brand-about-title">
  <div class="l-container">
    <!-- LINE chat container -->
    <div class="p-line-chat">
      <div class="p-line-chat__screen">
      <div class="p-line-chat__notch" aria-hidden="true"></div>
      <!-- LINE header -->
      <div class="p-line-chat__header">
        <button class="p-line-chat__header-back" aria-label="戻る">
          <svg width="10" height="18" viewBox="0 0 10 18" fill="none" aria-hidden="true">
            <path d="M9 1L1 9l8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <h2 id="brand-about-title" class="p-line-chat__header-title">
          <span class="p-line-chat__header-name">森半について</span>
          <span class="p-line-chat__header-sub">about MORIHAN</span>
        </h2>
        <div class="p-line-chat__header-icons">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.5"/>
            <line x1="15" y1="15" x2="18" y2="18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M3 4h14M3 10h14M3 16h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
      </div>

      <!-- Chat body -->
      <div class="p-line-chat__body">
        <!-- Initial bot message -->
        <div class="p-line-chat__row p-line-chat__row--bot p-line-chat__anim">
          <div
            class="p-line-chat__avatar p-line-chat__avatar--spacer"
            data-avatar="initial"
            aria-hidden="true"
          >
            <Image src={kumaIconInitial} alt="" class="p-line-chat__avatar-image" />
          </div>
          <div class="p-line-chat__bubble p-line-chat__bubble--bot">
            {chatData.messages[0].text}
          </div>
        </div>

        <!-- A/B choices -->
        <div class="p-line-chat__row p-line-chat__row--user p-line-chat__anim">
          <div class="p-line-chat__choices-layout">
            <div class="p-line-chat__choices-panel">
              <div class="p-line-chat__choices">
                {chatData.messages[1].options.map((opt) => (
                  <button
                    class="p-line-chat__choice-btn"
                    data-choice={opt.label.toLowerCase()}
                    type="button"
                  >
                    <span class="p-line-chat__choice-label">{opt.label}</span>
                    <span>{opt.text}</span>
                  </button>
                ))}
              </div>
            </div>
            <div class="p-line-chat__choices-icon" aria-hidden="true">
              <Image src={choiceIcon} alt="" class="p-line-chat__choices-icon-image" />
            </div>
          </div>
        </div>

        <!-- Reply A -->
        <div class="p-line-chat__reply" data-reply="a" hidden>
          {chatData.messages[2].texts.map((text, index) => (
            <div class="p-line-chat__row p-line-chat__row--bot p-line-chat__reply-msg">
              <div
                class="p-line-chat__avatar p-line-chat__avatar--spacer"
                data-avatar={`reply-a-${index + 1}`}
                aria-hidden="true"
              >
                <Image src={replyAAvatars[index] ?? kumaIconReplyA1} alt="" class="p-line-chat__avatar-image" />
              </div>
              <div class="p-line-chat__bubble p-line-chat__bubble--bot">
                {text.split('\n').map((line, i, arr) => (
                  <Fragment>
                    {line}
                    {i < arr.length - 1 && <br />}
                  </Fragment>
                ))}
              </div>
            </div>
          ))}
        </div>

        <!-- Reply B -->
        <div class="p-line-chat__reply" data-reply="b" hidden>
          <div class="p-line-chat__reply-b">
            <div class="p-line-chat__row p-line-chat__row--bot p-line-chat__reply-msg">
              <div class="p-line-chat__avatar p-line-chat__avatar--spacer" data-avatar="reply-b-1" aria-hidden="true">
                <Image src={replyBAvatars[0]} alt="" class="p-line-chat__avatar-image" />
              </div>
              <div class="p-line-chat__bubble p-line-chat__bubble--bot">
                {chatData.messages[3].texts[0]}
              </div>
            </div>

            <div class="p-line-chat__row p-line-chat__row--bot p-line-chat__reply-msg">
              <div class="p-line-chat__avatar p-line-chat__avatar--spacer" data-avatar="reply-b-2" aria-hidden="true">
                <Image src={replyBAvatars[1]} alt="" class="p-line-chat__avatar-image" />
              </div>
              <div class="p-line-chat__bubble p-line-chat__bubble--bot">
                {chatData.messages[3].texts[1]}
              </div>
            </div>

            <div class="p-line-chat__row p-line-chat__row--bot p-line-chat__reply-msg">
              <div class="p-line-chat__avatar p-line-chat__avatar--spacer" data-avatar="reply-b-3" aria-hidden="true">
                <Image src={kumaIconFooter} alt="" class="p-line-chat__avatar-image" />
              </div>
              <div class="p-line-chat__bubble p-line-chat__bubble--bot">
                森半ea&coffeeでは、まずはじめての方にも選びやすいギフトをご用意しています。用途に合わせて、贈りやすい組み合わせをご提案します。
              </div>
            </div>
          </div>
        </div>

        <!-- Reason carousel -->
        <ReasonCarousel
          carouselId="brand-carousel"
          heading={reasonHeading}
          ariaLabel={reasonHeading}
          cards={brandCarouselCards}
          containerClass="p-line-chat__after-reply"
          hidden
        />

        <ReasonCarousel
          carouselId="gift-carousel"
          heading="ギフトの選び方"
          ariaLabel="ギフトの選び方"
          cards={giftCarouselCards}
          containerClass="p-line-chat__after-reply p-line-chat__after-reply--gift"
          hidden
        />

        <!-- Footer message -->
        <div class="p-line-chat__row p-line-chat__row--bot p-line-chat__after-reply" hidden>
          <div
            class="p-line-chat__avatar p-line-chat__avatar--spacer"
            data-avatar="footer"
            aria-hidden="true"
          >
            <Image src={kumaIconFooter} alt="" class="p-line-chat__avatar-image" />
          </div>
          <div class="p-line-chat__bubble p-line-chat__bubble--bot p-line-chat__bubble--footer">
            {chatData.footer.text}
          </div>
        </div>
      </div>

      <!-- End of LINE chat -->
      </div>
    </div>
  </div>
</section>

<script>
  import Splide from '@splidejs/splide';
  import '@splidejs/splide/css/core';

  // A/B choice interactions
  const choiceBtns = document.querySelectorAll<HTMLButtonElement>('.p-line-chat__choice-btn');
  const replyA = document.querySelector<HTMLElement>('[data-reply="a"]');
  const replyB = document.querySelector<HTMLElement>('[data-reply="b"]');
  const afterReplyEls = document.querySelectorAll<HTMLElement>('.p-line-chat__after-reply:not(.p-line-chat__after-reply--gift)');
  const giftCarouselEls = document.querySelectorAll<HTMLElement>('.p-line-chat__after-reply--gift');
  let currentChoice: string | null = null;
  const mountedCarousels = new Set<string>();
  const carouselOptions = {
    type: 'loop',
    perPage: 1,
    perMove: 1,
    gap: '0px',
    padding: 0,
    trimSpace: true,
    pagination: true,
    arrows: true,
    autoplay: false,
    autoHeight: true,
  } as const;
  const carouselSelectors = {
    shared: ['#brand-carousel'],
    b: ['#gift-carousel'],
  } as const;
  const reasonCarouselRoots = document.querySelectorAll<HTMLElement>('[data-reason-carousel]');

  const mountCarousel = (selector: string) => {
    if (mountedCarousels.has(selector)) return;
    const element = document.querySelector<HTMLElement>(selector);
    if (!element) return;

    mountedCarousels.add(selector);
    new Splide(element, carouselOptions).mount();
  };

  const mountCarousels = (selectors: readonly string[]) => {
    selectors.forEach((selector) => mountCarousel(selector));
  };

  const syncReasonCarouselHeights = () => {
    reasonCarouselRoots.forEach((root) => {
      if (root.hidden || root.offsetParent === null) return;

      const slides = root.querySelectorAll<HTMLElement>('.splide__slide');
      const cards = root.querySelectorAll<HTMLElement>('[data-reason-carousel-card]');
      if (!slides.length || !cards.length) return;

      slides.forEach((slide) => {
        slide.style.height = 'auto';
      });
      cards.forEach((card) => {
        card.style.height = 'auto';
        card.style.minHeight = '0';
      });

      const maxHeight = Math.max(
        ...Array.from(cards).map((card) => card.getBoundingClientRect().height)
      );

      if (!Number.isFinite(maxHeight) || maxHeight <= 0) return;

      slides.forEach((slide) => {
        slide.style.height = `${maxHeight}px`;
      });

      cards.forEach((card) => {
        card.style.height = '100%';
        card.style.minHeight = `${maxHeight}px`;
      });
    });
  };

  const scheduleReasonCarouselSync = () => {
    window.requestAnimationFrame(() => {
      window.requestAnimationFrame(syncReasonCarouselHeights);
    });
  };

  window.addEventListener('load', scheduleReasonCarouselSync);
  window.addEventListener('resize', scheduleReasonCarouselSync);

  choiceBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const choice = btn.dataset.choice; // 'a' or 'b'
      if (choice === currentChoice) return; // ignore repeated clicks
      currentChoice = choice!;

      // Update selected state
      choiceBtns.forEach((b) => {
        b.classList.toggle('is-selected', b.dataset.choice === choice);
        b.classList.toggle('is-dimmed', b.dataset.choice !== choice);
      });

      // Toggle replies
      const showReply = choice === 'a' ? replyA : replyB;
      const hideReply = choice === 'a' ? replyB : replyA;

      if (hideReply) {
        hideReply.hidden = true;
        hideReply.querySelectorAll<HTMLElement>('.p-line-chat__reply-msg').forEach((msg) => {
          msg.classList.remove('is-visible');
        });
      }

      if (showReply) {
        showReply.hidden = false;
        const msgs = showReply.querySelectorAll<HTMLElement>('.p-line-chat__reply-msg');
        msgs.forEach((msg, i) => {
          msg.style.animationDelay = `${i * 0.3}s`;
          msg.classList.add('is-visible');
        });
      }

      // 共通の理由カルーセルとフッターを表示
      afterReplyEls.forEach((el) => {
        if (el.hidden) {
          el.hidden = false;
          el.style.animationDelay = '0.6s';
          el.classList.add('is-visible');
        }
      });
      if (choice === 'b') {
        giftCarouselEls.forEach((el) => {
          if (el.hidden) {
            el.hidden = false;
            el.style.animationDelay = '0.9s';
            el.classList.add('is-visible');
          }
        });
      } else {
        giftCarouselEls.forEach((el) => {
          el.hidden = true;
          el.classList.remove('is-visible');
        });
      }

      setTimeout(() => {
        mountCarousels(carouselSelectors.shared);
        if (choice === 'b') {
          mountCarousels(carouselSelectors.b);
        }
        scheduleReasonCarouselSync();
      }, 800);
    });
  });

  // Scroll animation for initial messages
  const chatBody = document.querySelector('.p-line-chat__body');
  if (chatBody) {
    const animElements = chatBody.querySelectorAll<HTMLElement>('.p-line-chat__anim');

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            animElements.forEach((el, i) => {
              el.style.animationDelay = `${i * 0.4}s`;
              el.classList.add('is-visible');
            });
            observer.disconnect();
          }
        });
      },
      { threshold: 0.2 }
    );

    observer.observe(chatBody);
  }
</script>


