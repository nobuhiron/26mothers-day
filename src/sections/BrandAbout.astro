---
/**
 * About section / LINE chat UI
 */
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import '@splidejs/splide/css/core';
import ReasonCarousel from '../components/ReasonCarousel.astro';
import chatData from '../data/line-chat.json';
import choiceIcon from '../assets/images/icon_usagi.png';
import { LINK_BASE } from '../data/links';
import { publicAssetPath } from '../utils/assets';

const brandEntries = await getCollection('brandCards');
const brandCarouselCards = brandEntries.map((entry) => ({
  reason: entry.data.reason,
  title: entry.data.title,
  description: entry.data.description,
  href: entry.data.href ?? LINK_BASE,
  image: entry.data.image,
  imageAlt: entry.data.imageAlt,
  reasonImage: entry.data.reasonImage,
  reasonImageAlt: entry.data.reasonImageAlt,
  buttons: entry.data.cta
    ? [{ label: entry.data.cta, href: entry.data.ctaHref ?? entry.data.href ?? LINK_BASE }]
    : [],
}));
const giftEntries = await getCollection('giftCards');
const giftCarouselCards = giftEntries.map((entry) => ({
  reason: entry.data.reason,
  title: entry.data.title,
  description: entry.data.description,
  href: entry.data.href ?? LINK_BASE,
  image: entry.data.image,
  imageAlt: entry.data.imageAlt,
  reasonImage: entry.data.reasonImage,
  reasonImageAlt: entry.data.reasonImageAlt,
  buttons: entry.data.buttons.map((button) =>
    typeof button === 'string'
      ? { label: button, href: entry.data.href ?? LINK_BASE }
      : { label: button.label, href: button.href ?? entry.data.href ?? LINK_BASE }
  ),
}));
---

<section id="about" class="l-section p-brand-about" aria-labelledby="brand-about-title">
  <div class="l-container">
    <!-- LINE chat container -->
    <div class="p-line-chat">
      <div class="p-line-chat__screen">
      <div class="p-line-chat__notch" aria-hidden="true"></div>
      <!-- LINE header -->
      <div class="p-line-chat__header">
        <button class="p-line-chat__header-back" aria-label="戻る">
          <svg width="8" height="14" viewBox="0 0 10 18" fill="none" aria-hidden="true">
            <path d="M9 1L1 9l8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <h2 id="brand-about-title" class="p-line-chat__header-title">
          <span class="p-line-chat__header-name">森半について</span>
          <span class="p-line-chat__header-sub">about MORIHAN</span>
        </h2>
        <div class="p-line-chat__header-icons">
          <img src={publicAssetPath('/icon-search.svg')} alt="" aria-hidden="true" width="20" height="20" />
          <img src={publicAssetPath('/icon-telephone.svg')} alt="" aria-hidden="true" width="20" height="20" />
          <img src={publicAssetPath('/icon-hamburger.svg')} alt="" aria-hidden="true" width="20" height="20" />
        </div>
      </div>

      <!-- Chat body -->
      <div class="p-line-chat__body">
        <!-- Initial bot message -->
        <div class="p-line-chat__row p-line-chat__row--bot p-line-chat__anim is-visible">
          <div
            class="p-line-chat__avatar p-line-chat__avatar--spacer"
            data-avatar="initial"
            aria-hidden="true"
          >
            <img
              src={publicAssetPath(chatData.messages[0].avatar)}
              alt=""
              loading="lazy"
              decoding="async"
              class="p-line-chat__avatar-image"
            />
          </div>
          <div class="p-line-chat__bubble p-line-chat__bubble--bot">
            {chatData.messages[0].text}
          </div>
        </div>

        <!-- A/B choices -->
        <div class="p-line-chat__row p-line-chat__row--user p-line-chat__anim is-visible">
          <div class="p-line-chat__choices-layout">
            <div class="p-line-chat__choices-panel">
              <div class="p-line-chat__choices">
                {chatData.messages[1].options.map((opt) => (
                  <button
                    class="p-line-chat__choice-btn"
                    data-choice={opt.label.toLowerCase()}
                    type="button"
                  >
                    <span class="p-line-chat__choice-label">{opt.label}</span>
                    <span>{opt.text}</span>
                  </button>
                ))}
              </div>
            </div>
            <div class="p-line-chat__choices-icon" aria-hidden="true">
              <Image src={choiceIcon} alt="" class="p-line-chat__choices-icon-image" />
            </div>
          </div>
        </div>

        <!-- Reply A -->
        <div class="p-line-chat__reply" data-reply="a" hidden>
          {chatData.messages[2].texts.map((text, index) => (
            <div class="p-line-chat__row p-line-chat__row--bot p-line-chat__reply-msg">
              <div
                class="p-line-chat__avatar p-line-chat__avatar--spacer"
                data-avatar={`reply-a-${index + 1}`}
                aria-hidden="true"
              >
                <img
                  src={publicAssetPath(chatData.messages[2].avatars?.[index] ?? chatData.messages[2].avatars?.[0] ?? '')}
                  alt=""
                  loading="lazy"
                  decoding="async"
                  class="p-line-chat__avatar-image"
                />
              </div>
              <div class="p-line-chat__bubble p-line-chat__bubble--bot">
                {text.split('\n').map((line, i, arr) => (
                  <Fragment>
                    {line}
                    {i < arr.length - 1 && <br />}
                  </Fragment>
                ))}
              </div>
            </div>
          ))}
        </div>

        <!-- Reply B -->
        <div class="p-line-chat__reply" data-reply="b" hidden>
          <div class="p-line-chat__reply-b">
            <div class="p-line-chat__row p-line-chat__row--bot p-line-chat__reply-msg">
              <div class="p-line-chat__avatar p-line-chat__avatar--spacer" data-avatar="reply-b-1" aria-hidden="true">
                <img
                  src={publicAssetPath(chatData.messages[3].avatars?.[0] ?? '')}
                  alt=""
                  loading="lazy"
                  decoding="async"
                  class="p-line-chat__avatar-image"
                />
              </div>
              <div class="p-line-chat__bubble p-line-chat__bubble--bot">
                {chatData.messages[3].texts[0]}
              </div>
            </div>

            <div class="p-line-chat__row p-line-chat__row--bot p-line-chat__reply-msg">
              <div class="p-line-chat__avatar p-line-chat__avatar--spacer" data-avatar="reply-b-2" aria-hidden="true">
                <img
                  src={publicAssetPath(chatData.messages[3].avatars?.[1] ?? '')}
                  alt=""
                  loading="lazy"
                  decoding="async"
                  class="p-line-chat__avatar-image"
                />
              </div>
              <div class="p-line-chat__bubble p-line-chat__bubble--bot">
                {chatData.messages[3].texts[1]}
              </div>
            </div>

          </div>
        </div>

        <!-- Reason carousel -->
        <ReasonCarousel
          carouselId="brand-carousel-a"
          eyebrow="Reason"
          eyebrowImageSrc="/Reason.svg"
          heading="森半が選ばれる理由"
          ariaLabel="森半が選ばれる理由"
          cards={brandCarouselCards}
          containerClass="p-line-chat__after-reply p-line-chat__after-reply--brand-a"
          hidden
        />

        <ReasonCarousel
          carouselId="brand-carousel-b"
          eyebrow="Brand"
          eyebrowImageSrc="/Brand.svg"
          heading="森半とは"
          ariaLabel="森半とは"
          cards={brandCarouselCards}
          containerClass="p-line-chat__after-reply p-line-chat__after-reply--brand-b"
          hidden
          tone="gold"
        />

        <div class="p-line-chat__row p-line-chat__row--bot p-line-chat__after-reply p-line-chat__after-reply--b-note" hidden>
          <div class="p-line-chat__avatar p-line-chat__avatar--spacer" data-avatar="reply-b-3" aria-hidden="true">
            <img
              src={publicAssetPath(chatData.messages[3].avatars?.[2] ?? '')}
              alt=""
              loading="lazy"
              decoding="async"
              class="p-line-chat__avatar-image"
            />
          </div>
          <div class="p-line-chat__bubble p-line-chat__bubble--bot">
            {chatData.messages[3].texts[2]}
          </div>
        </div>

        <ReasonCarousel
          carouselId="gift-carousel"
          eyebrow="Gift"
          eyebrowImageSrc="/Chosen.svg"
          heading="森半がギフトに選ばれる理由"
          ariaLabel="森半がギフトに選ばれる理由"
          cards={giftCarouselCards}
          containerClass="p-line-chat__after-reply p-line-chat__after-reply--gift"
          hidden
          tone="accent"
        />

        <!-- Footer message -->
        <div class="p-line-chat__row p-line-chat__row--bot p-line-chat__after-reply" hidden>
          <div
            class="p-line-chat__avatar p-line-chat__avatar--spacer"
            data-avatar="footer"
            aria-hidden="true"
          >
            <img
              src={publicAssetPath(chatData.footer.avatar)}
              alt=""
              loading="lazy"
              decoding="async"
              class="p-line-chat__avatar-image"
            />
          </div>
          <div class="p-line-chat__bubble p-line-chat__bubble--bot p-line-chat__bubble--footer">
            {chatData.footer.text}
          </div>
        </div>
      </div>

      <!-- End of LINE chat -->
      </div>
    </div>
  </div>
</section>

<script src={publicAssetPath('/vendor/splide.min.js')} defer></script>
<script src={publicAssetPath('/scripts/brand-about.js')} defer></script>

